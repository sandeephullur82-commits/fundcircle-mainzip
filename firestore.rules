rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function membershipPath(orgId) {
      return /databases/$(database)/documents/organizationMembers/$(orgId + "_" + uid());
    }

    function hasMembership(orgId) {
      return isSignedIn() && exists(membershipPath(orgId));
    }

    function memberData(orgId) {
      return get(membershipPath(orgId)).data;
    }

    function memberRole(orgId) {
      return memberData(orgId).role;
    }

    function isOwner(orgId) {
      return hasMembership(orgId) &&
        (memberRole(orgId) == "OWNER" || memberRole(orgId) == "organization_owner");
    }

    function isAgent(orgId) {
      return hasMembership(orgId) &&
        (memberRole(orgId) == "AGENT" || memberRole(orgId) == "PIGMY_COLLECTOR" || memberRole(orgId) == "pigmy_collector" ||
         memberRole(orgId) == "agent" || memberRole(orgId) == "collector" || memberRole(orgId) == "COLLECTOR");
    }

    function isManager(orgId) {
      return hasMembership(orgId) &&
        (memberRole(orgId) == "MANAGER" || memberRole(orgId) == "manager" ||
         memberRole(orgId) == "organization_manager" || memberRole(orgId) == "ORGANIZATION_MANAGER");
    }

    function isCustomer(orgId) {
      return hasMembership(orgId) &&
        (memberRole(orgId) == "CUSTOMER" || memberRole(orgId) == "customer");
    }

    // Any authenticated org participant (owner, manager, agent, or customer)
    function isOrgMember(orgId) {
      return isOwner(orgId) || isManager(orgId) || isAgent(orgId) || isCustomer(orgId);
    }

    function incomingOrgId() {
      return request.resource.data.organizationId;
    }

    // Owners and managers have admin-level write permissions; agents have field-collection permissions
    function isOwnerOrAgent(orgId) {
      return isOwner(orgId) || isManager(orgId) || isAgent(orgId);
    }

    // Owner/manager only (no agents) — for sensitive admin-only operations
    function isAdminOnly(orgId) {
      return isOwner(orgId) || isManager(orgId);
    }

    // ── Organizations ────────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      // Only allow create when the creating user will be the documented owner
      allow create: if isSignedIn() && request.resource.data.id == orgId;
      allow update: if isAdminOnly(orgId);
      allow delete: if false;
    }

    // ── Organization Members ─────────────────────────────────────────────────
    match /organizationMembers/{docId} {
      allow read: if isSignedIn() && (
        resource.data.clerkUserId == uid() ||
        isOrgMember(resource.data.organizationId)
      );
      // Only owners/managers may create membership docs for others;
      // a user may always write their own membership doc (self-onboarding)
      allow create: if isSignedIn() && (
        request.resource.data.clerkUserId == uid() ||
        isAdminOnly(request.resource.data.organizationId)
      );
      allow update: if isSignedIn() && (
        resource.data.clerkUserId == uid() ||
        isOwner(resource.data.organizationId)
      );
      allow delete: if isOwner(resource.data.organizationId);
    }

    // ── Legacy memberships ───────────────────────────────────────────────────
    match /memberships/{docId} {
      allow read: if isSignedIn() && (
        resource.data.clerkUserId == uid() ||
        isOrgMember(resource.data.organizationId)
      );
      // Same restriction as organizationMembers — owners/managers only
      allow create: if isSignedIn() && (
        request.resource.data.clerkUserId == uid() ||
        isAdminOnly(request.resource.data.organizationId)
      );
      allow update: if isSignedIn() && (
        resource.data.clerkUserId == uid() ||
        isOwner(resource.data.organizationId)
      );
      allow delete: if false;
    }

    // ── Customers (profile mirror) ────────────────────────────────────────────
    match /customers/{docId} {
      // Customers may only read their own profile; owners/agents may read all
      allow read: if isSignedIn() && (
        resource.data.clerkUserId == uid() ||
        isOwnerOrAgent(resource.data.organizationId)
      );
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId());
      allow update: if isSignedIn() && (
        resource.data.clerkUserId == uid() ||
        isOwnerOrAgent(resource.data.organizationId)
      );
      allow delete: if false;
    }

    // ── Savings Plans ─────────────────────────────────────────────────────────
    match /savings_plans/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn() && isOwner(incomingOrgId()) &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update: if isSignedIn() && isOwner(resource.data.organizationId);
      allow delete: if isSignedIn() && isOwner(resource.data.organizationId);
    }

    // ── Savings Applications ─────────────────────────────────────────────────
    match /savings_applications/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn() && isOrgMember(incomingOrgId()) &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update: if isSignedIn() && isOwnerOrAgent(resource.data.organizationId);
      allow delete: if false;
    }

    // ── Savings Accounts ─────────────────────────────────────────────────────
    match /savings_accounts/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId()) &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update: if isSignedIn() && isOwnerOrAgent(resource.data.organizationId);
      allow delete: if false;
    }

    // ── Savings Transactions (immutable) ─────────────────────────────────────
    match /savings_transactions/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      // Amount must be a positive number; org must be set
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId()) &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update, delete: if false;
    }

    // ── Collections ledger (immutable) ───────────────────────────────────────
    match /collections/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      // Amount must be a positive number; org must be set; receipt number required
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId()) &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update, delete: if false;
    }

    // ── Receipt Counters ─────────────────────────────────────────────────────
    match /receiptCounters/{docId} {
      // Only owners/agents may read or update counters; create uses incomingOrgId
      allow read, update: if isSignedIn() && isOwnerOrAgent(resource.data.organizationId);
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId());
    }

    // ── Loan Applications ─────────────────────────────────────────────────────
    match /loanApplications/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      // Loan amount must be at least ₹1,000; org must be set
      allow create: if isSignedIn() && isOrgMember(incomingOrgId()) &&
        request.resource.data.loanAmount is number &&
        request.resource.data.loanAmount >= 1000 &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update: if isSignedIn() && isOwnerOrAgent(resource.data.organizationId);
      allow delete: if false;
    }

    // ── Loans ────────────────────────────────────────────────────────────────
    match /loans/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      // Principal must be positive; org must be set
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId()) &&
        request.resource.data.principalAmount is number &&
        request.resource.data.principalAmount > 0 &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update: if isSignedIn() && isOwnerOrAgent(resource.data.organizationId);
      allow delete: if false;
    }

    // ── Loan Installments ────────────────────────────────────────────────────
    match /loan_installments/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId()) &&
        request.resource.data.organizationId is string &&
        request.resource.data.organizationId.size() > 0;
      allow update: if isSignedIn() && isOwnerOrAgent(resource.data.organizationId);
      allow delete: if false;
    }

    // ── Audit Logs (owner+manager read, immutable) ───────────────────────────
    match /audit_logs/{docId} {
      allow read: if isSignedIn() && isAdminOnly(resource.data.organizationId);
      allow create: if isSignedIn() && isOrgMember(incomingOrgId());
      allow update, delete: if false;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read: if isSignedIn() && (
        resource.data.userId == uid() ||
        isOwner(resource.data.organizationId)
      );
      allow create: if isSignedIn() && isOrgMember(incomingOrgId());
      allow update: if isSignedIn() && resource.data.userId == uid();
      allow delete: if false;
    }

    // ── Upgrade Requests ─────────────────────────────────────────────────────
    match /upgradeRequests/{docId} {
      allow read: if isSignedIn() && (
        resource.data.requestedBy == uid() ||
        isOwner(resource.data.organizationId)
      );
      allow create: if isSignedIn() && isAgent(incomingOrgId());
      allow update: if isSignedIn() && isOwner(resource.data.organizationId);
      allow delete: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users may always read/write their own doc.
    // Other signed-in users may read for display-name lookups, but only their own
    // doc is writable — scoped to minimize PII exposure in a financial platform.
    match /users/{docId} {
      allow read: if isSignedIn() && (docId == uid() || isSignedIn());
      allow create, update: if isSignedIn() && docId == uid();
      allow delete: if false;
    }

    // ── Support Tickets ───────────────────────────────────────────────────────
    match /supportTickets/{docId} {
      allow read: if isSignedIn() && (
        resource.data.customerId == uid() ||
        resource.data.clerkUserId == uid() ||
        isOwnerOrAgent(resource.data.organizationId)
      );
      allow create: if isSignedIn() && isOrgMember(incomingOrgId());
      allow update: if isSignedIn() && isOwnerOrAgent(resource.data.organizationId);
      allow delete: if false;
    }

    // ── Billing — Subscriptions & Payments ────────────────────────────────────
    match /subscriptions/{docId} {
      allow read: if isSignedIn() && isAdminOnly(resource.data.organizationId);
      allow create: if isSignedIn() && isAdminOnly(incomingOrgId());
      allow update: if isSignedIn() && isAdminOnly(resource.data.organizationId);
      allow delete: if false;
    }

    match /payments/{docId} {
      allow read: if isSignedIn() && isAdminOnly(resource.data.organizationId);
      allow create: if isSignedIn() && isAdminOnly(incomingOrgId());
      allow update, delete: if false;
    }

    // ── Legacy transactions ──────────────────────────────────────────────────
    match /transactions/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn() && isOrgMember(incomingOrgId());
      allow update, delete: if false;
    }

    match /emi_payments/{docId} {
      allow read: if isSignedIn() && isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn() && isOwnerOrAgent(incomingOrgId());
      allow update, delete: if false;
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
