{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"vite,api\" --prefix-colors \"cyan,green\" \"node_modules/.bin/vite --port=5000 --host=0.0.0.0\" \"tsx server/index.ts\"",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --format=esm --packages=external",
    "build": "npm run build:client && npm run build:server",
    "start": "NODE_ENV=production node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/backend": "^3.4.14",
    "@clerk/clerk-react": "^5.61.8",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dexie": "^4.4.3",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.19",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0"
  }
}
