# ─────────────────────────────────────────────────────────────────────────────
# FundCircle — Local Development Environment
# Copy this file to .env and fill in your values.
# Run: npm install && npm run dev
# App will be available at: http://localhost:5000
# ─────────────────────────────────────────────────────────────────────────────

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"

# Clerk redirect URLs — set these in your Clerk dashboard under:
# Configure → Paths:
#   Sign-in URL:            http://localhost:5000/auth/sign-in
#   Sign-up URL:            http://localhost:5000/auth/sign-up
#   After sign-in URL:      http://localhost:5000/auth/callback
#   After sign-up URL:      http://localhost:5000/auth/callback
#
# Configure → Restrictions → Allowlist (Invitations):
#   Redirect URL:           http://localhost:5000/accept-invitation
#
# Configure → Domains:
#   Add localhost as an allowed domain.

# ── Firebase (Firestore) ──────────────────────────────────────────────────────
# Get these from https://console.firebase.google.com → Project Settings → General → Your apps
# Also add "localhost" to Firebase → Authentication → Settings → Authorized domains
VITE_FIREBASE_API_KEY="AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Optional local port overrides ─────────────────────────────────────────────
# VITE_PORT=5000       # Vite dev server port (default: 5000)
# API_PORT=3001        # Express API server port (default: 3001)
